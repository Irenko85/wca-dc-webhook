# Monitor scope and language
WCA_COUNTRY_ISO2=CL
TZ=America/Santiago
NOTIFICATION_LANGUAGE=es

# Polling and alert thresholds
POLL_INTERVAL_SECONDS=3600
REGISTRATION_UPCOMING_MINUTES=90
REGISTRATION_OPEN_GRACE_MINUTES=90
SPOTS_WARNING_PERCENT=0.80
REQUEST_TIMEOUT_SECONDS=10

# Existing installations can omit the flags; credentials are detected.
DISCORD_ENABLED=true
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXX/YYYYY

TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=your_channel_id_here

# Persistent SQLite state
DB_PATH=/app/data/wca_tracker.sqlite3
